# OpenAI API Configuration
OPENAI_API_KEY=

# Primary recipient for daily digests
MY_EMAIL=

# Free Render-friendly email delivery via Resend
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_PROVIDER=auto

# Optional local SMTP fallback (not supported on free Render web services)
APP_PASSWORD=

# Webshare Proxy
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=

# Secures POST /run requests for the web service
RUN_API_TOKEN=

# Environment Configuration
# Set to LOCAL for local development, PRODUCTION for production (Render)
# If not set, defaults to LOCAL
ENVIRONMENT=LOCAL

# Database Configuration
# For Render: DATABASE_URL is automatically provided, no need to set individual vars
# For Local Development: Use individual POSTGRES_* variables below
DATABASE_URL=

# Local Development Database (only needed if DATABASE_URL is not set)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_news_aggregator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
